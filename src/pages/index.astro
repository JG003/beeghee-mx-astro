---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import PriceCard from '../components/PriceCard.astro';
import LeadForm from '../components/islands/LeadForm.tsx';
import { MX_SITE, PRICING } from '../data/site';

const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Beeghee — Pan de Abeja Fermentado en Colmena',
  description:
    'Complejo de polen y pan de abeja hive-fermented™ con cultivos activos en una crema untable probiótica.',
  brand: { '@type': 'Brand', name: 'Beeghee' },
  category: 'Alimento (No es un suplemento dietético)',
  image: 'https://mx.beeghee.energy/images/duo-pack.png',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'MXN',
    availability: 'https://schema.org/InStock',
    url: 'https://mx.beeghee.energy/tienda',
    areaServed: { '@type': 'Country', name: 'Mexico' },
  },
};
---
<BaseLayout
  title="Beeghee México — Superalimento Fermentado en Colmena | Pan de Abeja con Probióticos Vivos"
  description="Beeghee® es un superalimento bioactivo de pan de abeja fermentado en colmena, producido en Veracruz, México. Probióticos vivos para la salud digestiva."
  structuredData={productLd}
>
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-cover bg-center" style="background-image: url('/hero-beebread.jpg');"></div>
    <div class="absolute inset-0 -z-[5] bg-hero-slate/80 mix-blend-multiply"></div>

    <div class="relative z-10 container py-24 md:py-32">
      <div class="flex flex-col md:flex-row items-center justify-center gap-10 md:gap-14 text-center md:text-left">
        <div class="w-full md:w-auto flex justify-center">
          <img
            src="/beeghee-jars.png"
            alt="Beeghee jars - Tangy Original y Sweet Velvet"
            class="w-full max-w-[480px] md:max-w-[520px] drop-shadow-2xl"
            loading="eager"
          />
        </div>

        <div class="w-full md:max-w-xl space-y-6 text-white drop-shadow-md">
          <span class="inline-block bg-primary/90 text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full">
            Hecho en México para México
          </span>

          <h1 class="text-4xl md:text-5xl font-extrabold leading-tight">
            Beeghee: Fermento Bioactivo de Colmena
          </h1>

          <p class="text-lg md:text-xl text-white/90">
            Energía limpia para tu día. Suministro de 30 días por frasco (9 oz).
          </p>

          <div class="flex flex-col sm:flex-row gap-3 pt-2 justify-center md:justify-start">
            <WhatsAppCTA text={MX_SITE.whatsappPrefill} variant="large" />
            <div class="w-full sm:w-auto">
              <LeadForm client:visible tag="mx-home" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-hero-slate py-16">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center space-y-4">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8a2 2 0 0 0 1.3 1.3L21 12l-5.8 1.9a2 2 0 0 0-1.3 1.3L12 21l-1.9-5.8a2 2 0 0 0-1.3-1.3L3 12l5.8-1.9a2 2 0 0 0 1.3-1.3L12 3z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-white">Energía Natural</h3>
          <p class="text-white/70">Sin azúcares refinados ni cafeína. Energía limpia y duradera.</p>
        </div>

        <div class="text-center space-y-4">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3-3.6 15.7-8.2 17.04Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-white">100% Natural</h3>
          <p class="text-white/70">Ingredientes orgánicos fermentados con cultivos bioactivos.</p>
        </div>

        <div class="text-center space-y-4">
          <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center mx-auto">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-white">Salud Intestinal</h3>
          <p class="text-white/70">Apoya tu microbioma con enzimas y probióticos naturales.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Nuestros Productos</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto">
        Elige el formato perfecto para ti. Todos con envío a toda la República Mexicana.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <PriceCard product={PRICING.tangy}>
        <WhatsAppCTA text={PRICING.tangy.ctaText} />
      </PriceCard>
      <PriceCard product={PRICING.double}>
        <WhatsAppCTA text={PRICING.double.ctaText} />
      </PriceCard>
      <PriceCard product={PRICING.velvet}>
        <WhatsAppCTA text={PRICING.velvet.ctaText} />
      </PriceCard>
    </div>
  </section>

  <section class="py-16 bg-cream-accent">
    <div class="container max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-semibold text-center mb-2">Formas de Pago</h2>
      <p class="text-sm text-neutral-600 text-center mb-8">
        Elige la forma de pago que más te convenga. Todas las opciones se confirman por WhatsApp.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="flex items-start gap-3 rounded-2xl border border-secondary bg-white/80 px-4 py-4 shadow-sm">
          <div class="mt-1 flex h-10 w-10 items-center justify-center rounded-full bg-secondary/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7 12 2"/></svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-neutral-900">Transferencia bancaria (SPEI)</h3>
            <p class="text-xs text-neutral-600">Te compartimos los datos de cuenta para hacer tu transferencia segura.</p>
          </div>
        </div>

        <div class="flex items-start gap-3 rounded-2xl border border-secondary bg-white/80 px-4 py-4 shadow-sm">
          <div class="mt-1 flex h-10 w-10 items-center justify-center rounded-full bg-secondary/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-neutral-900">Efectivo / depósito bancario</h3>
            <p class="text-xs text-neutral-600">Puedes pagar en ventanilla o depósito en efectivo, confirmando tu pago por WhatsApp.</p>
          </div>
        </div>

        <div class="flex items-start gap-3 rounded-2xl border border-secondary bg-white/80 px-4 py-4 shadow-sm">
          <div class="mt-1 flex h-10 w-10 items-center justify-center rounded-full bg-secondary/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="currentColor"><path d="M11.385 5.85q.25-1.07 1.34-.81l.61.13-.4 1.64-.37-.1c-.25-.04-.38.02-.41.21l-.41 1.72 1.95.52q1.03.26.89 1.53l-.22.98q.72.47.44 1.56c-.28 1.08-.84 1.45-1.68 1.2l-.4 1.75-.97-.25.41-1.71-.78-.21-.41 1.72-.97-.25.4-1.73-1.95-.5.24-1.02l.65.17q.45.09.53-.27l.76-3.2q.11-.49-.32-.6l-.64-.18.25-.97l1.95.52.6-2.54z"/></svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-neutral-900">Bitcoin (BTC)</h3>
            <p class="text-xs text-neutral-600">Aceptamos pago directo en Bitcoin. Te enviamos la wallet y el monto exacto en satoshis.</p>
          </div>
        </div>

        <div class="flex items-start gap-3 rounded-2xl border border-secondary bg-white/60 px-4 py-4 shadow-sm opacity-80">
          <div class="mt-1 flex h-10 w-10 items-center justify-center rounded-full bg-neutral-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-neutral-900">
              Tarjeta de crédito/débito
              <span class="ml-1 text-xs font-normal text-primary">(próximamente)</span>
            </h3>
            <p class="text-xs text-neutral-600">Muy pronto podrás pagar con tarjeta directamente desde la página.</p>
          </div>
        </div>
      </div>

      <p class="mt-6 text-[11px] text-center text-neutral-500">
        Después de elegir tu forma de pago, confirmamos tu pedido y envío por WhatsApp.
      </p>
    </div>
  </section>
</BaseLayout>
