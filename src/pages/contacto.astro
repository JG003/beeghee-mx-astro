---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import LeadForm from '../components/islands/LeadForm.tsx';

const contactLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contacto | Beeghee México',
  url: 'https://mx.beeghee.energy/contacto',
  inLanguage: 'es-MX',
  mainEntity: {
    '@id': 'https://mx.beeghee.energy/#organization',
  },
};
---
<BaseLayout
  title="Contacto | Beeghee México — WhatsApp y Redes"
  description="Contacta a Beeghee México por WhatsApp o correo. +52 981 819 8199. ¿Preguntas, pedidos o colaboraciones? Estamos para ayudarte."
  structuredData={contactLd}
>
  <section class="bg-hero-slate py-20">
    <div class="container text-center text-white max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Contacto</h1>
      <p class="text-lg text-white/80">
        ¿Preguntas, pedidos o colaboraciones? Estamos para ayudarte.
      </p>
    </div>
  </section>

  <section class="container py-16 max-w-4xl">
    <div class="grid md:grid-cols-2 gap-10">
      <div class="space-y-6">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 bg-whatsapp/10 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-whatsapp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <div>
            <h2 class="text-xl font-semibold">WhatsApp</h2>
            <p class="text-sm text-muted-foreground">Nuestro canal principal</p>
          </div>
        </div>
        <p class="text-muted-foreground">
          Haz tu pedido, pregunta sobre productos o resuelve cualquier duda directamente con nuestro equipo.
        </p>
        <WhatsAppCTA text="Hola! Quiero información sobre Beeghee." variant="large" />
        <p class="text-xs text-muted-foreground">+52 981 819 8199</p>
      </div>

      <div class="space-y-6">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h2 class="text-xl font-semibold">Correo</h2>
            <p class="text-sm text-muted-foreground">Déjanos tu email</p>
          </div>
        </div>
        <p class="text-muted-foreground">
          Recibe información, ofertas y novedades sobre Beeghee directo en tu bandeja.
        </p>
        <LeadForm client:visible tag="mx-contacto" placeholder="tu@correo.com" buttonText="Enviar" />

        <div class="pt-4">
          <h3 class="text-sm font-semibold mb-3">Síguenos</h3>
          <div class="flex items-center gap-3">
            <a href="https://x.com/BEEGHEE_energy" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="X (Twitter)">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://facebook.com/beeghee.energy" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.89 3.77-3.89 1.09 0 2.24.19 2.24.19v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12"/></svg>
            </a>
            <a href="https://instagram.com/beeghee.energy" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://tiktok.com/@beeghee.energy" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="TikTok">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
            </a>
            <a href="https://beeghee.energy/news" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Noticias RSS">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream-accent py-12">
    <div class="container text-center max-w-2xl">
      <div class="flex items-center justify-center gap-2 mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        <h2 class="text-xl font-semibold">¿Fuera de México?</h2>
      </div>
      <p class="text-muted-foreground mb-4 text-sm">
        Visita nuestro sitio principal para pedidos internacionales.
      </p>
      <a
        href="https://beeghee.co"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors"
      >
        beeghee.co
      </a>
    </div>
  </section>
</BaseLayout>
