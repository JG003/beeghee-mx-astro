---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="404 — Página no encontrada | Beeghee México"
  description="Oops — esta página no existe."
  hideModal={true}
  hideChat={true}
>
  <div class="flex min-h-[60vh] items-center justify-center bg-muted">
    <div class="text-center">
      <h1 class="mb-4 text-6xl font-bold">404</h1>
      <p class="mb-4 text-xl text-muted-foreground">Oops — página no encontrada</p>
      <a href="/" class="text-primary underline hover:text-primary/90">Volver al inicio</a>
    </div>
  </div>
</BaseLayout>
