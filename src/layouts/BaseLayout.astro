---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/islands/ChatWidget.tsx';
import NewVisitorModal from '../components/islands/NewVisitorModal.tsx';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  structuredData?: any;
  lang?: string;
  hideChat?: boolean;
  hideModal?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://mx.beeghee.energy/images/duo-pack.png',
  structuredData,
  lang = 'es-MX',
  hideChat = false,
  hideModal = false,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

const orgWebsite = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://mx.beeghee.energy/#organization',
      name: 'Beeghee México',
      url: 'https://mx.beeghee.energy',
      logo: 'https://mx.beeghee.energy/beeghee-logo.png',
      description:
        'Superalimento bioactivo de pan de abeja fermentado en colmena, producido en Veracruz, México.',
      parentOrganization: {
        '@type': 'Organization',
        name: 'Beeghee Inc',
        url: 'https://beeghee.co',
      },
      areaServed: { '@type': 'Country', name: 'Mexico' },
      sameAs: [
        'https://beeghee.co',
        'https://x.com/BEEGHEE_energy',
        'https://instagram.com/beeghee.energy',
        'https://facebook.com/beeghee.energy',
        'https://tiktok.com/@beeghee.energy',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://mx.beeghee.energy/#website',
      name: 'Beeghee México',
      url: 'https://mx.beeghee.energy',
      inLanguage: 'es-MX',
      publisher: { '@id': 'https://mx.beeghee.energy/#organization' },
    },
  ],
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Beeghee" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="alternate" hreflang="es-MX" href="https://mx.beeghee.energy/" />
    <link rel="alternate" hreflang="en" href="https://beeghee.co/" />
    <link rel="alternate" hreflang="en-CA" href="https://ca.beeghee.energy/" />
    <link rel="alternate" hreflang="x-default" href="https://beeghee.co/" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="en_CA" />
    <meta property="og:site_name" content="Beeghee México" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(orgWebsite)} />
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    {!hideModal && <NewVisitorModal client:idle />}
    {!hideChat && <ChatWidget client:idle />}
  </body>
</html>
