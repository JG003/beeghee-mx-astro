---
import type { ArticleEntry } from '../lib/articles';
import { articleHref } from '../lib/articles';

export interface Props {
  article: ArticleEntry;
  readingTimeMinutes?: number;
}

const { article, readingTimeMinutes } = Astro.props;
const href = articleHref(article);
---
<article class="group rounded-xl bg-card shadow-sm hover:shadow-md transition-shadow overflow-hidden border border-border/40">
  <a href={href} class="block">
    <div class="aspect-[16/9] overflow-hidden bg-muted">
      <img
        src={article.data.hero}
        alt={article.data.heroAlt}
        width="1200"
        height="675"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
      />
    </div>
    <div class="p-5 md:p-6">
      <h2 class="text-xl md:text-2xl font-bold text-foreground leading-snug">
        {article.data.title}
      </h2>
      <p class="mt-3 text-sm md:text-base text-muted-foreground line-clamp-3">
        {article.data.excerpt}
      </p>
      {readingTimeMinutes !== undefined && (
        <div class="mt-4 flex items-center gap-2 text-xs text-muted-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{readingTimeMinutes} min de lectura</span>
        </div>
      )}
    </div>
  </a>
</article>
