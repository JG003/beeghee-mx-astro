---
import { whatsappUrl } from '../data/site';

export interface Props {
  text: string;
  variant?: 'default' | 'large';
  buttonText?: string;
  href?: string;
  class?: string;
}

const {
  text,
  variant = 'default',
  buttonText = 'Comprar por WhatsApp',
  href,
  class: extraClass = '',
} = Astro.props;

const url = href ?? whatsappUrl(text);
const sizeClass =
  variant === 'large'
    ? 'px-6 py-3 text-base'
    : 'px-4 py-2 text-sm';
---
<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class={`inline-flex items-center gap-2 rounded-lg bg-whatsapp text-whatsapp-foreground font-semibold hover:bg-whatsapp/90 transition-all duration-300 hover:scale-105 ${sizeClass} ${extraClass}`}
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
  {buttonText}
</a>
